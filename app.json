{
  "expo": {
    "name": "AccelLearn",
    "slug": "AccelLearn",
    "scheme": "accellearn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "userInterfaceStyle": "automatic",
    "description": "Supercharge your memory with spaced repetition. Register tasks with your results, and AccelLearn automatically schedules reviews at Day+1, Week+1, and Week+3 — based on the Ebbinghaus forgetting curve. Stop forgetting what you've learned.",
    "privacyPolicyUrl": "https://takuaki-taku.github.io/AccelLearn/",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.accellearn.app",
      "infoPlist": {
        "NSPrivacyTrackingUsageDescription": "This app does not track you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.accellearn.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "6789f7e6-1d40-4104-af72-bc6b4b9fec00"
      }
    }
  }
}
